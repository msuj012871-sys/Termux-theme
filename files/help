#!/usr/bin/env bash

# Colors
r='\033[1;91m'
p='\033[1;95m'
y='\033[1;93m'
g='\033[1;92m'
n='\033[0m'
b='\033[1;94m'
c='\033[1;96m'

# Symbols
X='\033[1;92m[\033[1;00mвҺҜкҜӯМҪр“Ҷ©\033[1;92m]\033[1;96m'
D='\033[1;92m[\033[1;00mгҖ„\033[1;92m]\033[1;93m'
E='\033[1;92m[\033[1;00mГ—\033[1;92m]\033[1;91m'
A='\033[1;92m[\033[1;00m+\033[1;92m]\033[1;92m'
C='\033[1;92m[\033[1;00m</>\033[1;32m]\033[1;92m'

# Icons
aHELL="\uf489"
USER="\uf007"

# Username Fetch Logic
if [ -d "/data/data/com.termux/files/usr/" ]; then
    DIR="$HOME/.termux"
else
    DIR="$HOME/.CODEX"
fi

USERNAME_FILE="$DIR/usernames.txt"

if [ -f "$USERNAME_FILE" ]; then
    username=$(cat "$USERNAME_FILE")
fi

random_number=$(( RANDOM % 2 ))

# Exit Trap Function
exit_script() {
    echo
    echo -e "${c}              (\_/)"
    echo -e "              (${y}^_^${c})     ${A} ${g}Hey dear${c}"
    echo -e "             вҠӮ(___)гҒҘ  вӢ…ЛҡвӮҠвҖ§ а¬і вҖ§вӮҠЛҡ вӢ…"
    echo
    echo -e " ${A} ${c}Exiting ${g}help menu \033[1;36m"
    echo
    exit 0
}

trap exit_script SIGINT SIGTSTP

# Cross-Platform Device Detection (Termux & Linux)
if command -v getprop &> /dev/null; then
    MODEL=$(getprop ro.product.model)
    VENDOR=$(getprop ro.product.manufacturer)
else
    MODEL=$(hostname)
    VENDOR=$(uname -o)
fi
devicename="${VENDOR} ${MODEL}"

# Disk Usage Function
THRESHOLD=100
check_disk_usage() {
    local threshold=${1:-$THRESHOLD}
    local total_size
    local used_size
    local disk_usage

    total_size=$(df -h "$HOME" | awk 'NR==2 {print $2}')
    used_size=$(df -h "$HOME" | awk 'NR==2 {print $3}')
    disk_usage=$(df "$HOME" | awk 'NR==2 {print $5}' | sed 's/%//g')

    if [ "$disk_usage" -ge "$threshold" ]; then
        echo -e "${g}[${n}\uf0a0${g}] ${r}WARN: ${y}Disk Full ${g}${disk_usage}% ${c}| ${c}U${g}${used_size} ${c}of ${c}T${g}${total_size}"
    else
        echo -e "${y}Disk usage: ${g}${disk_usage}% ${c}| ${g}${used_size}"
    fi
}

data=$(check_disk_usage)

if [ $random_number -eq 0 ]; then
    echo -e "\n\n              ${g}Hey ${y}$username"
    echo -e "${c}         (\_/)"
    echo -e "         (${y}^Пү^${c})     ${g}I'm Dx-Simu${c}"
    echo -e "        вҠӮ(___)гҒҘ  вӢ…ЛҡвӮҠвҖ§ а¬і вҖ§вӮҠЛҡ вӢ…"
    echo
    echo -e " ${A} ${c}All Command ${g}Codex BannerВЎ${c}"
else
    echo -e "\n\n   ${c}___  _  _       __  __  ___  ___  _  _"
    echo -e "  ${c}(   \( \/ )___  / _)/  \(   \(  _)( \/ )"
    echo -e "  ${n} ) ) ))  ((___)( (_( () )) ) )) _) )  ("
    echo -e " ${y} (___/(_/\_)     \__)\__/(___/(___)(_/\_)"
    echo
    echo -e " ${A} ${c}All Command ${g}Codex BannerВЎ${c}"
fi

# Info Section
echo -e "\n${b}в•ӯв•җв•җ ${g}гҖ„ ${y}бҙ„бҙҸбҙ…бҙҮx ${g}гҖ„"
echo -e "${b}в”ғвқҒ ${g}бҙ„КҖбҙҮбҙҖбҙӣбҙҸКҖ: ${y}бҙ…x-бҙ„бҙҸбҙ…бҙҮx"
echo -e "${b}в”ғвқҒ ${g}бҙ…бҙҮбҙ ЙӘбҙ„бҙҮ: ${y}${devicename}"
echo -e "${b}в”ғвқҒ ${g}бҙ…ЙӘкңұбҙӢ: ${y}${data}"
echo -e "${b}в•°в”ҲвһӨ ${g}[${n}${USER}${g}] ${g}Hey ${y}${username}"
echo
echo -e "${b}в•ӯв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җвҠ·"
echo -e "${b}в”ғ ${g}[${n}\uf6c3${g}] ${y}бҙҖКҹКҹ бҙ„бҙҸбҙҚбҙҚбҙҖЙҙбҙ…"
echo -e "${b}в•°в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җвҠ·${n}"
echo

# Command/Alias List
echo -e "${b}в•ӯв•җв•җв•җв•җв•җвқӮ ${g}${aHELL} бҙ„бҙҸбҙҚбҙҚбҙҖЙҙбҙ… ${b}вқӮв•җв•җв•җв•җв•җвҠ·"
echo -e "${b}в”ғ ${p}вқҸ ${g}help       ${p}[бҙ„бҙҸбҙ…бҙҮx КңбҙҮКҹбҙҳ бҙҚбҙҮЙҙбҙң]"
echo -e "${b}в”ғ ${p}вқҸ ${g}bname      ${p}[бҙ„КңбҙҖЙҙЙўбҙҮ КҷбҙҖЙҙЙҙбҙҮКҖ ЙҙбҙҖбҙҚбҙҮ]"
echo -e "${b}в”ғ ${p}вқҸ ${g}unstall    ${p}[бҙңЙҙЙӘЙҙкңұбҙӣбҙҖКҹКҹ кңұбҙ„КҖЙӘбҙҳбҙӣ/бҙӣбҙҸбҙҸКҹкңұ]"
echo -e "${b}в”ғ ${p}вқҸ ${g}chat       ${p}[бҙ„бҙҸбҙ…бҙҮx ЙўКҹбҙҸКҷбҙҖКҹ бҙ„КңбҙҖбҙӣ]"
echo -e "${b}в”ғ ${p}вқҸ ${g}dev        ${p}[КҖбҙҮбҙҳбҙҸКҖбҙӣ бҙ…бҙҮбҙ бҙҮКҹбҙҸбҙҳбҙҮКҖ]"
echo -e "${b}в”ғ ${p}вқҸ ${g}report     ${p}[КҖбҙҮбҙҳбҙҸКҖбҙӣ бҙ…бҙҮбҙ бҙҮКҹбҙҸбҙҳбҙҮКҖ]"
echo -e "${b}в”ғ ${p}вқҸ ${g}update     ${p}[бҙңбҙҳбҙ…бҙҖбҙӣбҙҮ бҙ„бҙҸбҙ…бҙҮx КҷбҙҖЙҙЙҙбҙҮКҖ]"
echo -e "${b}в•°в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җвҠ·"
echo
echo -e "${b}в•ӯв•җв•җв•җв•җв•җвқӮ ${g}${aHELL} бҙҚЙӘЙҙЙӘ бҙ„бҙҸбҙҚбҙҚбҙҖЙҙбҙ… ${b}вқӮв•җв•җв•җв•җв•җвҠ·"
echo -e "${b}в”ғ ${p}вқҸ ${g}ls       ${p}[КҹЙӘsбҙӣ бҙҖКҹКҹ]"
echo -e "${b}в”ғ ${p}вқҸ ${g}lt       ${p}[КҹЙӘsбҙӣ бҙ…бҙҮТ“бҙҖбҙңКҹбҙӣ]"
echo -e "${b}в”ғ ${p}вқҸ ${g}clear    ${p}[бҙ„КҹбҙҮбҙҖКҖ sбҙ„КҖбҙҮбҙҮЙҙ КҷбҙҖЙҙЙҙбҙҮКҖ]"
echo -e "${b}в”ғ ${p}вқҸ ${g}clear n  ${p}[бҙ„КҹбҙҮбҙҖКҖ sбҙ„КҖбҙҮбҙҮЙҙ бҙ…бҙҮТ“бҙҖбҙңКҹбҙӣ]"
echo -e "${b}в”ғ ${p}вқҸ ${g}exit     ${p}[бҙҮxЙӘбҙӣ бҙ…бҙҮТ“бҙҖбҙңКҹбҙӣ]"
echo -e "${b}в”ғ ${p}вқҸ ${g}exit x   ${p}[бҙҮxЙӘбҙӣ бҙҖбҙ…бҙ бҙҖЙҙбҙ„бҙҮ]"
echo -e "${b}в•°в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җвҠ·"


